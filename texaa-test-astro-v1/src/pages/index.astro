---
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

// Hero (LCP)
import heroCinematic from '../assets/hero/hero-cinematic.jpg';

// Génère les variantes WebP et récupère les attributs srcset/sizes pour le preload
const heroPreload = await getImage({
	src: heroCinematic,
	width: 1920,
	height: 1536,
	widths: [768, 1280, 1920],
	format: 'webp',
	quality: 72,
});

// References
import refLeTronquay from '../assets/references/le-tronquay.jpg';
import refMairieBidart from '../assets/references/mairie-bidart.jpg';
import refMuseeMarine from '../assets/references/musee-national-marine.jpg';

// Markets
import marketBureaux from '../assets/markets/bureaux.jpg';
import marketAccueil from '../assets/markets/espace-accueil.jpg';
import marketTechnique from '../assets/markets/technique-son.jpg';
import marketRestaurant from '../assets/markets/restaurant.jpg';
import marketSante from '../assets/markets/sante.jpg';
import marketEnseignement from '../assets/markets/enseignement.jpg';

// Products
import productVibrasto from '../assets/products/vibrasto.png';
import productStereo from '../assets/products/stereo.png';
import productStereoAir from '../assets/products/stereo-air.png';
import productStrato from '../assets/products/strato.png';
import productAbso from '../assets/products/abso.png';

// Heritage
import heritageHopital from '../assets/heritage/hopital-arnaud-de-villeneuve.jpg';
import heritageAtelier from '../assets/heritage/atelier-texaa.jpg';
import logoEpv from '../assets/heritage/logo-epv.png';

// Logos clients
import logoHermes from '../assets/logos/hermes.png';
import logoSyctom from '../assets/logos/syctom.png';
import logoRatp from '../assets/logos/ratp.png';
import logoSncf from '../assets/logos/sncf.svg';
import logoNovotel from '../assets/logos/novotel.png';
import logoLdlc from '../assets/logos/ldlc.webp';
import logoLedger from '../assets/logos/ledger.png';
import logoRepubliqueFrancaise from '../assets/logos/republique-francaise.png';

const phoneNumber = "05 56 46 01 63";
const phoneLink = "tel:+33556460163";

const references = [
	{
		title: "Groupe scolaire Le Tronquay",
		project: "Groupe scolaire",
		year: "2024",
		location: "Le Tronquay, France",
		client: "Groupe Scolaire le Tronquay",
		architect: "Camélia Alex-Letenneur Architecte",
		acoustician: "DB-Therm BET acoustique",
		photographer: "Guillaume Jouet",
		image: refLeTronquay
	},
	{
		title: "Mairie de Bidart",
		project: "Mairie de Bidart",
		year: "2022",
		location: "Bidart, France",
		client: "Mairie de Bidart",
		photographer: "Arnaud Brossard",
		image: refMairieBidart
	},
	{
		title: "Musée National de la Marine",
		project: "Musée National de la Marine",
		year: "2023",
		location: "Paris",
		architect: "h2o architectes et Snøhetta",
		acoustician: "Acoustique Impédance ingénierie",
		photographer: "Maxime Verret",
		image: refMuseeMarine
	}
];

const whyTexaaFeatures = [
	{
		number: "01",
		title: "Expertise textile & acoustique",
		description: "Nos produits combinent performance acoustique mesurée et qualité textile haut de gamme. La matière est au cœur de notre savoir-faire, pas un simple habillage."
	},
	{
		number: "02",
		title: "Gamme complète, cohérente",
		description: "Plafonds, murs, suspensions, mobilier — une gamme conçue pour répondre à chaque configuration, avec cohérence esthétique et technique entre les produits."
	},
	{
		number: "03",
		title: "Production en France",
		description: "Fabrication à Bordeaux. Délais maîtrisés, traçabilité assurée, flexibilité sur les commandes spécifiques et les teintes hors catalogue."
	}
];

const trustedLogos = [
	{ name: "Hermès", logo: logoHermes },
	{ name: "Syctom", logo: logoSyctom },
	{ name: "RATP", logo: logoRatp },
	{ name: "SNCF", logo: logoSncf },
	{ name: "Novotel", logo: logoNovotel },
	{ name: "LDLC Arena", logo: logoLdlc },
	{ name: "Ledger", logo: logoLedger },
	{ name: "La République Française", logo: logoRepubliqueFrancaise }
];

const markets = [
	{
		number: "01",
		title: "Espaces de travail",
		description: "Open-spaces, salles de réunion, espaces collaboratifs",
		image: marketBureaux
	},
	{
		number: "02",
		title: "Accueil & réception",
		description: "Halls d'entrée, banques d'accueil, lobbies hôteliers",
		image: marketAccueil
	},
	{
		number: "03",
		title: "Technique & son",
		description: "Studios, auditoriums, salles de conférence haute exigence",
		image: marketTechnique
	},
	{
		number: "04",
		title: "Restaurant & hôtellerie",
		description: "Restaurants, cafés, espaces de restauration, hôtels",
		image: marketRestaurant
	},
	{
		number: "05",
		title: "Santé",
		description: "Hôpitaux, cliniques, EHPAD, espaces de soin",
		image: marketSante
	},
	{
		number: "06",
		title: "Enseignement",
		description: "Écoles, universités, centres de formation, bibliothèques",
		image: marketEnseignement
	}
];


const faqs = [
	{
		question: "Vos solutions sont-elles adaptées aux ERP et aux contraintes réglementaires ?",
		answer: "Oui, nos produits sont conçus pour répondre aux exigences des établissements recevant du public (ERP). Nous fournissons les fiches techniques et procès-verbaux nécessaires (réaction au feu, données acoustiques) pour la conformité de votre projet. N'hésitez pas à nous consulter pour vérifier l'adéquation de nos solutions avec vos contraintes spécifiques."
	},
	{
		question: "Proposez-vous des solutions sur-mesure (dimensions, coloris) ?",
		answer: "Oui, nous proposons une large palette de coloris et pouvons adapter les dimensions de nos produits à votre projet. Notre production française nous permet de répondre aux demandes spécifiques. Contactez nos équipes pour discuter de vos besoins particuliers et obtenir des échantillons dans les coloris souhaités."
	},
	{
		question: "Comment se déroule l'accompagnement projet avec Texaa ?",
		answer: "Notre accompagnement comprend : l'analyse de votre problématique acoustique, la préconisation de solutions adaptées, l'aide au dimensionnement et au positionnement des produits, la fourniture de la documentation technique pour vos dossiers, et le suivi jusqu'à la livraison. Nous travaillons régulièrement avec les architectes, bureaux d'études et maîtres d'ouvrage à toutes les phases du projet."
	},
	{
		question: "Est-ce que l'installation nécessite de fermer mon établissement ?",
		answer: "Non, la plupart de nos solutions se posent rapidement sans poussière ni nuisances majeures."
	},
];

---

<Layout
	preloadHref={heroPreload.src}
	preloadImagesrcset={heroPreload.srcSet?.attribute}
	preloadImagesizes="100vw"
>
	<!-- Sticky Header (Desktop) -->
	<header class="sticky-header" id="stickyHeader">
		<div class="sticky-header-inner">
			<a href="/" class="sticky-logo">TEXAA</a>
			<nav class="sticky-cta" aria-label="Actions principales">
				<a href={phoneLink} class="sticky-phone">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
					</svg>
					{phoneNumber}
				</a>
				<a href="#contact-form" class="btn btn-primary btn-sm">Demander un devis</a>
			</nav>
		</div>
	</header>

	<!-- Mobile Sticky CTA -->
	<div class="mobile-sticky-cta">
		<a href={phoneLink}>
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
			</svg>
			Appeler un expert
		</a>
	</div>

	<!-- HERO SECTION — Cinématique : photo plein écran, contenu bas avec barre de stats -->
	<section class="hero hero-cinematic">
		<div class="hero-image">
			<Image
				src={heroCinematic}
				alt="Espace architectural traité acoustiquement par Texaa"
				width={1920}
				height={1536}
				widths={[768, 1280, 1920]}
				sizes="100vw"
				format="webp"
				quality={72}
				loading="eager"
				fetchpriority="high"
			/>
			<div class="hero-cinematic-overlay"></div>
		</div>
		<div class="container">
			<div class="hero-cinematic-content">
				<div class="hero-cinematic-top">
					<div class="hero-label">
						<span></span>
						Fabricant français depuis 1979
					</div>

					<h1>Réduisez le bruit dans vos espaces et améliorez immédiatement l'expérience client</h1>

					<p class="hero-subtitle">
						Solutions acoustiques textiles sur mesure, conçues et fabriquées en France pour bureaux, hôtels et espaces recevant du public.
					</p>

					<div class="hero-cta">
						<a href={phoneLink} class="btn btn-primary btn-lg">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
							{phoneNumber}
						</a>
						<a href="https://texaa.fr/echantillons/" class="btn btn-secondary btn-lg">
							Demander des échantillons
						</a>
					</div>
				</div>

				<div class="hero-cinematic-stats">
					<div class="hero-stat">
						<span class="hero-stat-number">500+</span>
						<span class="hero-stat-label">Projets architecturaux</span>
					</div>
					<div class="hero-stat-divider"></div>
					<div class="hero-stat">
						<span class="hero-stat-number">45 ans</span>
						<span class="hero-stat-label">D'expertise acoustique</span>
					</div>
					<div class="hero-stat-divider"></div>
					<div class="hero-stat">
						<span class="hero-stat-number">100%</span>
						<span class="hero-stat-label">Fabrication française</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- LOGO BANNER - ILS NOUS FONT CONFIANCE -->
	<section class="logo-banner">
		<div class="container">
			<div class="logo-banner-header">
				<div class="logo-banner-line"></div>
				<p class="logo-banner-title">Ils nous font confiance pour leurs projets d'exception</p>
				<div class="logo-banner-line"></div>
			</div>
			<div class="logo-banner-grid">
				{trustedLogos.map((logo) => (
					<div class="logo-banner-item">
						<Image src={logo.logo} alt={logo.name} width={220} height={130} widths={[160, 220]} sizes="(max-width: 768px) 33vw, 160px" format="webp" loading="lazy" />
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- IMPACT SECTION -->
	<section class="impact-section section">
		<div class="container">
			<div class="section-header">
				<span class="section-label">Pourquoi agir</span>
				<h2>Une mauvaise acoustique impacte votre activité</h2>
				<p>Dans les espaces professionnels et publics, le bruit excessif et la réverbération génèrent des problèmes concrets.</p>
				<p class="impact-cta-text"><strong>Ne laissez plus l'acoustique freiner votre activité. Texaa transforme ces nuisances en un atout design et serein.</strong></p>
			</div>

			<div class="impact-grid">

				<div class="impact-card">
					<div class="impact-icon">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
						</svg>
					</div>
					<h3>Perte de concentration</h3>
					<p>Les environnements réverbérants rendent difficile la concentration. Chaque interruption sonore nécessite un temps de récupération cognitif.</p>
				</div>

				<div class="impact-card">
					<div class="impact-icon">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
						</svg>
					</div>
					<h3>Intelligibilité réduite</h3>
					<p>La réverbération excessive brouille la parole. Dans les salles de réunion, restaurants ou classes, les échanges deviennent difficiles.</p>
				</div>

				<div class="impact-card">
					<div class="impact-icon">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
						</svg>
					</div>
					<h3>Contraintes réglementaires</h3>
					<p>Les normes acoustiques (code du travail, réglementation ERP, accessibilité) imposent des niveaux de performance à respecter.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- SOLUTION SECTION -->
	<section class="solution-section section-lg">
		<div class="container">
			<div class="solution-header">
				<div class="solution-header-line"></div>
				<h2>La réponse : le textile acoustique haute performance</h2>
				<p>Texaa conçoit des solutions où la matière textile est au cœur de la performance acoustique. Pas un simple habillage, mais un système technique complet.</p>
			</div>

			<div class="solution-products-grid">
				<a href="#contact-form" class="solution-product-card">
					<div class="solution-product-image">
						<Image src={productVibrasto} alt="Vibrasto - Revêtements acoustiques" width={540} height={539} widths={[300, 540]} sizes="(max-width: 768px) 50vw, 280px" format="webp" quality={75} loading="lazy" />
					</div>
					<div class="solution-product-content">
						<span class="solution-product-type">Revêtements acoustiques</span>
						<h3>Vibrasto</h3>
						<p>Pour habiller tout type de parois réverbérantes.</p>
					</div>
					<div class="solution-product-cta">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>

				<a href="#contact-form" class="solution-product-card">
					<div class="solution-product-image">
						<Image src={productStereo} alt="Stereo - Panneaux acoustiques" width={540} height={539} widths={[300, 540]} sizes="(max-width: 768px) 50vw, 280px" format="webp" quality={75} loading="lazy" />
					</div>
					<div class="solution-product-content">
						<span class="solution-product-type">Panneaux acoustiques</span>
						<h3>Stereo</h3>
						<p>Groupés ou isolés dans le volume, pour s'adapter aux configurations les plus diverses.</p>
					</div>
					<div class="solution-product-cta">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>

				<a href="#contact-form" class="solution-product-card">
					<div class="solution-product-image">
						<Image src={productStereoAir} alt="Stereo Air - Panneaux ajourés" width={540} height={540} widths={[300, 540]} sizes="(max-width: 768px) 50vw, 280px" format="webp" quality={75} loading="lazy" />
					</div>
					<div class="solution-product-content">
						<span class="solution-product-type">Panneaux</span>
						<h3>Stereo Air</h3>
						<p>Panneau ajouré pour habiller les fonctions techniques (lumière, ventilation, etc.).</p>
					</div>
					<div class="solution-product-cta">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>

				<a href="#contact-form" class="solution-product-card">
					<div class="solution-product-image">
						<Image src={productStrato} alt="Strato - Plafond flottant" width={540} height={539} widths={[300, 540]} sizes="(max-width: 768px) 50vw, 280px" format="webp" quality={75} loading="lazy" />
					</div>
					<div class="solution-product-content">
						<span class="solution-product-type">Plafond</span>
						<h3>Strato</h3>
						<p>Plafond flottant composé de panneaux acoustiques Stereo et de panneaux ajourés Stereo Air.</p>
					</div>
					<div class="solution-product-cta">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>

				<a href="#contact-form" class="solution-product-card">
					<div class="solution-product-image">
						<Image src={productAbso} alt="Abso - Objets acoustiques" width={540} height={539} widths={[300, 540]} sizes="(max-width: 768px) 50vw, 280px" format="webp" quality={75} loading="lazy" />
					</div>
					<div class="solution-product-content">
						<span class="solution-product-type">Objets acoustiques</span>
						<h3>Abso</h3>
						<p>Volumes ultra-légers et ultra-absorbants, mobiles ou fixes.</p>
					</div>
					<div class="solution-product-cta">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>
			</div>

			<div class="solution-cta">
				<a href="#contact-form" class="btn btn-outline-red btn-lg">
					Demander des échantillons textiles
				</a>
			</div>
		</div>
	</section>

	<!-- WHY TEXAA SECTION -->
	<section class="why-section section-lg">
		<div class="container">
			<div class="why-layout">
				<div class="why-content">
					<span class="why-label">Pourquoi Texaa</span>
					<h2>L'expertise d'un atelier français depuis 1979</h2>

					<div class="why-features">
						{whyTexaaFeatures.map((feature) => (
							<div class="why-feature">
								<div class="why-feature-number">{feature.number}</div>
								<div class="why-feature-content">
									<h3>{feature.title}</h3>
									<p>{feature.description}</p>
								</div>
							</div>
						))}
					</div>

					<div class="why-cta-group">
						<a href={phoneLink} class="btn btn-primary btn-lg">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
							{phoneNumber}
						</a>
						<a href="#contact-form" class="btn btn-outline-dark">
							Envoyer une demande
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>
				</div>

				<div class="why-image">
					<Image src={heritageHopital} alt="Réalisation Texaa - Traitement acoustique" width={1200} height={800} widths={[600, 1200]} sizes="(max-width: 768px) 100vw, 50vw" format="webp" quality={72} loading="lazy" />
					<div class="why-image-caption">
						<span class="why-image-label">Réalisation</span>
						<p>Hall de l'hôpital Arnaud de Villeneuve — Traitement acoustique plafond, intégration sur mesure dans un contexte architectural exigeant.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- METHOD SECTION -->
	<section class="method-section section">
		<div class="container">
			<div class="method-header">
				<span class="method-label">Notre méthode</span>
				<h2>De l'analyse au résultat mesurable</h2>
