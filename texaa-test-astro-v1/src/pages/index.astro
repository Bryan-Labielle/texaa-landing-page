<script>
	// Sticky Header
	const stickyHeader = document.getElementById('stickyHeader');
	const heroSection = document.querySelector('.hero');

	function handleScroll() {
		if (heroSection && stickyHeader) {
			const heroBottom = heroSection.offsetTop + heroSection.offsetHeight;
			if (window.scrollY > heroBottom - 100) {
				stickyHeader.classList.add('visible');
			} else {
				stickyHeader.classList.remove('visible');
			}
		}
	}

	window.addEventListener('scroll', handleScroll);

	// FAQ Accordion
	const faqItems = document.querySelectorAll('.faq-item');

	faqItems.forEach(item => {
		const question = item.querySelector('.faq-question');

		question?.addEventListener('click', () => {
			const isOpen = item.classList.contains('open');

			// Close all items
			faqItems.forEach(i => i.classList.remove('open'));

			// Open clicked item if it wasn't open
			if (!isOpen) {
				item.classList.add('open');
			}
		});
	});

	// Smooth scroll for anchor links
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function(e) {
			const href = this.getAttribute('href');
			if (href && href !== '#') {
				e.preventDefault();
				const target = document.querySelector(href);
				if (target) {
					target.scrollIntoView({
						behavior: 'smooth',
						block: 'start'
					});
				}
			}
		});
	});

	// Lead form submission → Make webhook
	const WEBHOOK_URL = 'https://hook.eu1.make.com/REPLACE_ME_WITH_REAL_WEBHOOK_ID';
	const leadForm = document.getElementById('leadForm') as HTMLFormElement | null;

	if (leadForm) {
		const submitBtn = leadForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		const errorBox = document.getElementById('formError');

		leadForm.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!submitBtn) return;

			const formData = new FormData(leadForm);
			const payload = {
				lastname: formData.get('lastname'),
				firstname: formData.get('firstname'),
				establishment_type: formData.get('establishment_type'),
				city: formData.get('city'),
				phone: formData.get('phone'),
				email: formData.get('email'),
				comments: formData.get('comments') || '',
				documents: formData.getAll('documents'),
				submitted_at: new Date().toISOString(),
				source: 'solutions.texaa.fr',
			};

			// UI : état chargement
			submitBtn.classList.add('is-loading');
			submitBtn.disabled = true;
			errorBox?.classList.remove('is-visible');

			try {
				const response = await fetch(WEBHOOK_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				if (!response.ok) {
					throw new Error(`HTTP ${response.status}`);
				}

				// Succès : redirection vers la page de remerciement
				window.location.href = '/merci';
			} catch (err) {
				// Échec : on restaure le bouton et affiche le message d'erreur
				submitBtn.classList.remove('is-loading');
				submitBtn.disabled = false;
				errorBox?.classList.add('is-visible');
			}
		});
	}

	// References : <details> ouvert sur desktop, repliable sur mobile
	const referencesDetails = document.querySelectorAll('.reference-card-content');
	const desktopMq = window.matchMedia('(min-width: 1025px)');

	function syncReferenceDetails(matches: boolean) {
		referencesDetails.forEach(d => {
			if (matches) {
				d.setAttribute('open', '');
			} else {
				d.removeAttribute('open');
			}
		});
	}

	syncReferenceDetails(desktopMq.matches);
	desktopMq.addEventListener('change', e => syncReferenceDetails(e.matches));
</script>
