---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const phoneNumber = "05 56 46 01 63";
const phoneLink = "tel:+33556460163";
---

<Layout
	title="Merci — Votre demande a bien été reçue | Texaa"
	description="Votre demande a bien été envoyée. Un expert Texaa vous recontactera dans les meilleurs délais pour étudier votre projet acoustique."
>
	<header class="merci-header">
		<div class="container">
			<a href="/" class="merci-header-logo" aria-label="Texaa — Accueil">
				<svg width="144" height="35" viewBox="0 0 144 35" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
