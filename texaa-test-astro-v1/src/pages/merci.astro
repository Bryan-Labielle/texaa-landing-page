4 26.272 117.808 27.664C116.8 29.008 115.264 29.872 113.296 29.872C110.992 29.872 109.216 28.96 109.216 26.848Z" fill="currentColor"/>
					<path d="M127.858 8.322C127.858 12.7 131.422 16.264 135.8 16.264C140.178 16.264 143.742 12.7 143.742 8.322C143.742 3.944 140.178 0.379999 135.8 0.379999C131.422 0.379999 127.858 3.944 127.858 8.322ZM130.146 8.322C130.146 4.67 132.61 2.14 135.8 2.14C138.946 2.14 141.454 4.67 141.454 8.322C141.454 11.996 138.946 14.504 135.8 14.504C132.61 14.504 130.146 11.996 130.146 8.322ZM132.61 12.7H134.502V8.96H135.404L137.516 12.7H139.452L137.12 8.872C138.484 8.762 139.452 8.124 139.452 6.518C139.452 4.538 138.176 3.878 135.932 3.878H132.61V12.7ZM134.502 7.508V5.33H135.844C136.592 5.33 137.56 5.44 137.56 6.342C137.56 7.354 136.944 7.508 136.042 7.508H134.502Z" fill="currentColor"/>
				</svg>
			</a>
			<a href={phoneLink} class="merci-header-phone">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
				</svg>
				{phoneNumber}
			</a>
		</div>
	</header>

	<main class="merci-main">
		<div class="container">
			<div class="merci-card">

				<span class="merci-label">
					<span></span>
					Demande reçue
				</span>

				<h1>Merci pour votre demande</h1>

				<p class="merci-lead">
					Votre message nous est bien parvenu. Un expert Texaa vous recontactera dans les meilleurs délais pour étudier votre projet acoustique.
				</p>

				<div class="merci-steps">
					<h2 class="merci-steps-title">Les prochaines étapes</h2>

					<div class="merci-step">
						<div class="merci-step-number">01</div>
						<div class="merci-step-content">
							<h3>Étude de votre demande</h3>
							<p>Notre équipe analyse votre problématique acoustique sous 24 h ouvrées.</p>
						</div>
					</div>

					<div class="merci-step">
						<div class="merci-step-number">02</div>
						<div class="merci-step-content">
							<h3>Prise de contact</h3>
							<p>Un expert vous contacte pour affiner vos besoins et répondre à vos questions.</p>
						</div>
					</div>

					<div class="merci-step">
						<div class="merci-step-number">03</div>
						<div class="merci-step-content">
							<h3>Préconisation technique</h3>
							<p>Vous recevez une préconisation adaptée avec documentation et dimensionnement.</p>
						</div>
					</div>
				</div>

				<div class="merci-contact">
					<p class="merci-contact-label">Besoin d'une réponse immédiate ?</p>
					<a href={phoneLink} class="btn btn-primary btn-lg">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
						</svg>
						{phoneNumber}
					</a>
				</div>

				<a href="/" class="btn btn-secondary btn-lg merci-back">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					Retour à l'accueil
				</a>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.merci-header {
		background: var(--white);
		border-bottom: 1px solid var(--gray-200);
		padding: 20px 0;
	}

	.merci-header .container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.merci-header-logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		color: var(--texaa-red);
	}

	.merci-header-logo svg {
		height: 28px;
		width: auto;
	}

	.merci-header-phone {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--gray-700);
		text-decoration: none;
		font-size: 15px;
		font-weight: 600;
		transition: color var(--transition-fast);
	}

	.merci-header-phone:hover {
		color: var(--texaa-red);
	}

	.merci-header-phone svg {
		width: 18px;
		height: 18px;
		color: var(--texaa-red);
	}

	.merci-main {
		background: var(--white);
		min-height: calc(100vh - 150px);
		padding: 120px 0;
		display: flex;
		align-items: center;
	}

	.merci-card {
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
	}

	.merci-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: var(--texaa-red);
		color: var(--white);
		margin-bottom: 24px;
		box-shadow: 0 6px 16px rgba(255, 0, 0, 0.25);
	}

	.merci-icon svg {
		width: 18px;
		height: 18px;
	}

	.merci-label {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 8px 16px;
		background: var(--texaa-red-light);
		color: var(--texaa-red);
		border: 1px solid rgba(255, 0, 0, 0.2);
		border-radius: 100px;
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 32px;
	}

	.merci-label > span {
		width: 6px;
		height: 6px;
		background: var(--texaa-red);
		border-radius: 50%;
	}

	.merci-card h1 {
		font-size: clamp(36px, 4.5vw, 48px);
		color: var(--gray-900);
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin: 0 0 28px;
	}

	.merci-lead {
		font-size: 19px;
		line-height: 1.7;
		color: var(--gray-600);
		max-width: 560px;
		margin: 0 auto 80px;
	}

	.merci-steps {
		text-align: left;
		max-width: 560px;
		margin: 0 auto 80px;
		padding-top: 64px;
		border-top: 1px solid var(--gray-200);
	}

	.merci-steps-title {
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--gray-500);
		text-align: center;
		margin: 0 0 40px;
	}

	.merci-step {
		display: flex;
		gap: 24px;
		align-items: flex-start;
		margin-bottom: 36px;
	}

	.merci-step:last-child {
		margin-bottom: 0;
	}

	.merci-step-number {
		flex-shrink: 0;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: var(--texaa-red-light);
		color: var(--texaa-red);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 15px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.merci-step-content h3 {
		font-size: 17px;
		color: var(--gray-900);
		margin: 0 0 6px;
		line-height: 1.3;
	}

	.merci-step-content p {
		font-size: 15px;
		color: var(--gray-600);
		line-height: 1.6;
		margin: 0;
	}

	.merci-contact {
		padding-top: 64px;
		border-top: 1px solid var(--gray-200);
		margin-bottom: 48px;
	}

	.merci-contact-label {
		font-size: 15px;
		color: var(--gray-600);
		margin: 0 0 20px;
	}

	.merci-contact .btn svg {
		width: 20px;
		height: 20px;
	}

	.merci-back svg {
		width: 18px;
		height: 18px;
	}

	@media (max-width: 768px) {
		.merci-main {
			padding: 72px 0;
		}

		.merci-icon {
			width: 38px;
			height: 38px;
			margin-bottom: 20px;
		}

		.merci-icon svg {
			width: 17px;
			height: 17px;
		}

		.merci-lead {
			font-size: 17px;
			margin-bottom: 56px;
		}

		.merci-steps {
			padding-top: 48px;
			margin-bottom: 56px;
		}

		.merci-steps-title {
			margin-bottom: 32px;
		}

		.merci-step {
			margin-bottom: 28px;
		}

		.merci-contact {
			padding-top: 48px;
		}
	}
</style>
