---
const phoneNumber = "05 56 46 01 63";
const phoneLink = "tel:+33556460163";
---

<footer class="footer">
	<div class="container">
		<div class="footer-grid">
			<div class="footer-brand">
				<a href="/" class="footer-logo">TEXAA</a>
				<p class="footer-tagline">
					Solutions acoustiques textiles sur-mesure, conçues et fabriquées en France depuis 1979.
				</p>
			</div>

			<nav class="footer-nav" aria-label="Navigation pied de page">
				<h2 class="footer-heading">Navigation</h2>
				<ul>
					<li><a href="/#references">Réalisations</a></li>
					<li><a href="/#marches">Marchés</a></li>
					<li><a href="/#heritage">Notre savoir-faire</a></li>
					<li><a href="/#faq">Questions fréquentes</a></li>
					<li><a href="/#contact-form">Demander un devis</a></li>
				</ul>
			</nav>

			<div class="footer-contact">
				<h2 class="footer-heading">Contact</h2>
				<ul>
					<li>
						<a href={phoneLink}>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
							{phoneNumber}
						</a>
					</li>
					<li>
						<span>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
							Bordeaux, France
						</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<p class="footer-copyright">© 2026 Texaa. Tous droits réservés.</p>
			<div class="footer-bottom-right">
				<a href="/mentions-legales">Mentions légales</a>
				<button type="button" class="footer-back-top" id="footerBackTop" aria-label="Retour en haut de page">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
					</svg>
					Retour en haut
				</button>
			</div>
		</div>
	</div>
</footer>

<script>
	document.getElementById('footerBackTop')?.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
</script>
