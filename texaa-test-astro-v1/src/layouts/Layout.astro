	/* Heritage Section - Durabilité */
	.heritage-section {
		background: linear-gradient(135deg, #F8F6F3 0%, #F0EDE8 100%);
	}

	.heritage-header {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 56px;
	}

	.heritage-header h2 {
		font-size: clamp(28px, 4vw, 40px);
		color: var(--gray-900);
	}

	.heritage-main {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 56px;
		align-items: center;
		margin-bottom: 48px;
	}

	.heritage-visual {
		position: relative;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--shadow-xl);
	}

	.heritage-visual > img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		display: block;
	}

	.heritage-visual-badge {
		position: absolute;
		bottom: 20px;
		right: 20px;
		background: var(--white);
		padding: 12px 16px;
		border-radius: 8px;
		box-shadow: var(--shadow-lg);
	}

	.heritage-visual-badge img {
		height: 50px;
		width: auto;
	}

	.heritage-content {
		display: flex;
		flex-direction: column;
		gap: 32px;
	}

	.heritage-epv-text h3 {
		font-size: 24px;
		color: var(--gray-900);
		margin-bottom: 16px;
	}

	.heritage-epv-text p {
		font-size: 16px;
		line-height: 1.7;
		color: var(--gray-600);
	}

	.heritage-features {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.heritage-feature {
		display: flex;
		gap: 16px;
		align-items: flex-start;
	}

	.heritage-feature-icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--texaa-red-light);
		border-radius: 10px;
	}

	.heritage-feature-icon svg {
		width: 20px;
		height: 20px;
		color: var(--texaa-red);
	}

	.heritage-feature h4 {
		font-size: 16px;
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: 4px;
	}

	.heritage-feature p {
		font-size: 14px;
		line-height: 1.5;
		color: var(--gray-600);
	}

	/* Markets Header */
	.markets-header {
		background: var(--gray-900);
		padding: 88px 24px 64px;
		position: relative;
	}

	.markets-header::after {
		content: "";
		position: absolute;
		left: 50%;
		bottom: 32px;
		width: 56px;
		height: 2px;
		background: var(--texaa-red);
		transform: translateX(-50%);
		border-radius: 2px;
	}

	.markets-header-inner {
		max-width: 760px;
		margin: 0 auto;
		text-align: center;
	}

	.markets-eyebrow {
		display: inline-flex;
		align-items: center;
