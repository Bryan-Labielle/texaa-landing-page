		}

		.references-grid {
			grid-template-columns: 1fr;
		}

		.reference-card-image {
			height: 240px;
		}

		/* <= 1024px : <details> en mode accordéon (dropdown) */
		.reference-card-content {
			padding: 0;
		}

		.reference-card-content > *:not(summary) {
			display: none;
		}

		.reference-card-content[open] > *:not(summary) {
			display: block;
		}

		.reference-card-summary {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 16px;
			pointer-events: auto;
			cursor: pointer;
			user-select: none;
			padding: 20px 24px;
			background: var(--gray-50);
			border-top: 1px solid var(--gray-200);
			transition: background var(--transition-fast);
		}

		.reference-card-summary:hover,
		.reference-card-summary:active {
			background: var(--gray-100);
		}

		.reference-card-summary h3 {
			font-size: 17px;
			margin-bottom: 0;
			color: var(--gray-900);
		}

		.reference-card-summary h3::after {
			content: " — voir les détails";
			font-size: 12px;
			font-weight: 500;
			color: var(--texaa-red);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			display: block;
			margin-top: 4px;
		}

		.reference-card-content[open] .reference-card-summary h3::after {
			content: " — masquer les détails";
		}

		.reference-card-chevron {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 36px;
			height: 36px;
			border-radius: 50%;
			background: var(--texaa-red);
			color: var(--white);
			padding: 8px;
			box-shadow: 0 2px 8px rgba(255, 0, 0, 0.25);
		}

		.reference-card-content[open] .reference-card-chevron {
			transform: rotate(180deg);
		}

		.reference-card-content[open] .reference-details {
			margin: 0;
			padding: 20px 24px 24px;
			background: var(--white);
		}

		.method-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 32px 0;
		}

		.method-step {
			border-left: none;
			border-top: 1px solid var(--gray-300);
			padding: 24px 24px 0 0;
		}

		.method-step:nth-child(1),
		.method-step:nth-child(2) {
			border-top: none;
			padding-top: 0;
		}

		.method-step:nth-child(odd) {
			padding-left: 0;
		}

		.method-step:nth-child(even) {
			padding-left: 24px;
			border-left: 1px solid var(--gray-300);
		}

		.zones-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.hero-cinematic {
			min-height: 65vh;
		}

		.logo-banner-item img {
			max-height: 32px;
			max-width: 100px;
		}

		.btn {
			padding: 14px 24px;
			font-size: 15px;
		}

		.btn-lg {
			padding: 16px 28px;
			font-size: 16px;
		}

		.btn svg {
			width: 18px;
			height: 18px;
		}

		.action-grid {
			grid-template-columns: 1fr;
			gap: 48px;
		}

		.samples-grid {
			grid-template-columns: 1fr;
		}

		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 48px;
		}

		.footer-brand {
			grid-column: 1 / -1;
			max-width: 100%;
		}
	}

